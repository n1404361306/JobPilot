APP_NAME=JobPilot API
ENV=dev
DEBUG=true
API_V1_PREFIX=/api

SECRET_KEY=change_me_to_a_long_random_string
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=10080
JWT_ALGORITHM=HS256

MYSQL_USER=jobpilot
MYSQL_PASSWORD=jobpilot
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DB=jobpilot

# 本机快速跑通推荐 SQLite；部署 MySQL 时可注释本行，改用上方 MYSQL_* 配置。
DATABASE_URL=sqlite:///./jobpilot_dev.db

REDIS_URL=redis://127.0.0.1:6379/0

LOG_LEVEL=INFO

AI_PRIMARY_PROVIDER=deepseek
AI_PRIMARY_KEY=
AI_PRIMARY_BASE_URL=https://api.deepseek.com
AI_PRIMARY_MODEL=deepseek-chat
AI_FALLBACK_ENABLED=false
AI_TIMEOUT_SECONDS=60
AI_TEMPERATURE=0.2
AI_MAX_TOKENS=4096

UPLOAD_DIR=uploads
OCR_ENGINE=rapidocr
OCR_LANG=ch
OCR_MAX_FILE_SIZE_MB=10
